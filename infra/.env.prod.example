# ── 复制为 /opt/playmate/.env.prod，填入真实值，绝不提交 git ────────────────

# PostgreSQL
POSTGRES_PASSWORD=请改为强密码
DATABASE_URL=postgres://playmate:请改为强密码@127.0.0.1:5432/playmate

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT（openssl rand -base64 48 生成，至少 32 位）
JWT_SECRET=请改为强随机字符串
JWT_REFRESH_SECRET=请改为另一个强随机字符串

# 服务监听
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 对象存储（MinIO 本机部署）
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_PUBLIC_ENDPOINT=http://<服务器公网IP>:9000   # 手机能访问到的地址
STORAGE_ACCESS_KEY=请改为MinIO用户名
STORAGE_SECRET_KEY=请改为MinIO密码
STORAGE_REGION=us-east-1

# MinIO docker-compose 用（与上方 ACCESS_KEY/SECRET_KEY 保持一致）
MINIO_ROOT_USER=请改为MinIO用户名
MINIO_ROOT_PASSWORD=请改为MinIO密码

# 微信开放平台（不用微信登录可留空）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 阿里云短信（留空则打印日志，生产必填）
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=搭伴
ALIYUN_SMS_TEMPLATE_CODE=

# 日志
RUST_LOG=playmate=info,tower_http=info,sqlx=warn
