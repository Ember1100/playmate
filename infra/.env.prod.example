# ── 复制为 infra/.env.prod，填入真实值，绝不提交 git ─────────────────────────

# PostgreSQL（docker-compose.prod.yml 使用，同时也是 DATABASE_URL 的密码部分）
POSTGRES_PASSWORD=请改为强密码

# 应用数据库连接串（Rust 服务读取）
DATABASE_URL=postgres://playmate:请改为强密码@127.0.0.1:5432/playmate

# Redis 连接串（Rust 服务读取）
REDIS_URL=redis://127.0.0.1:6379

# JWT（openssl rand -base64 48 生成，至少32位）
JWT_SECRET=请改为强随机字符串
JWT_REFRESH_SECRET=请改为另一个强随机字符串

# 服务监听
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 微信开放平台（不用微信登录可留空）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 阿里云短信（留空则打印日志，生产必填）
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=玩伴
ALIYUN_SMS_TEMPLATE_CODE=

# 日志
RUST_LOG=playmate=info,tower_http=info,sqlx=warn
