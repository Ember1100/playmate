# ── 数据库 ────────────────────────────────────────────────────
DATABASE_URL=postgres://playmate:playmate@localhost:5432/playmate
POSTGRES_PASSWORD=playmate                   # docker-compose 用

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT（生产环境请替换为 32+ 位随机字符串）──────────────────
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# ── 服务监听 ──────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── 对象存储（开发：MinIO，生产：替换为阿里云 OSS）──────────
MINIO_ROOT_USER=playmate                     # docker-compose 用
MINIO_ROOT_PASSWORD=playmate123              # docker-compose 用

STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=playmate
STORAGE_SECRET_KEY=playmate123
STORAGE_REGION=us-east-1

# 生产换 OSS 时只改这几行（代码不动）：
# STORAGE_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
# STORAGE_PUBLIC_ENDPOINT=https://<bucket>.oss-cn-hangzhou.aliyuncs.com
# STORAGE_ACCESS_KEY=<阿里云 AccessKeyId>
# STORAGE_SECRET_KEY=<阿里云 AccessKeySecret>
# STORAGE_REGION=cn-hangzhou

# ── 微信开放平台 ──────────────────────────────────────────────
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ── 阿里云短信（为空时 dev 模式：验证码打印到日志）───────────
ALIYUN_SMS_ACCESS_KEY=your_access_key
ALIYUN_SMS_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=搭伴
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx

# ── 日志 ──────────────────────────────────────────────────────
RUST_LOG=playmate=debug,tower_http=debug,sqlx=warn
