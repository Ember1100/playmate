# ── 数据库 ────────────────────────────────────────────────────
DATABASE_URL=postgres://playmate:playmate@localhost:5432/playmate

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT（生产环境请替换为 32+ 位随机字符串）──────────────────
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# ── 服务监听 ──────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── 微信开放平台 ──────────────────────────────────────────────
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ── 阿里云短信（为空时 dev 模式：验证码打印到日志）───────────
ALIYUN_SMS_ACCESS_KEY=your_access_key
ALIYUN_SMS_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=玩伴
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx

# ── 日志 ──────────────────────────────────────────────────────
RUST_LOG=playmate=debug,tower_http=debug,sqlx=warn
